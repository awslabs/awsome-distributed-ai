AWSTemplateFormatVersion: '2010-09-09'
Description: >
  AWS PCS Cluster with Login and Compute Node Groups.
  This template creates the PCS cluster, login node group, and optional compute node groups.
  Prerequisites (VPC, FSx) must be deployed separately or via deploy-all template.

Parameters:
  # Stack Name
  ClusterStackName:
    Type: String
    Description: Name for this cluster stack (used for tagging)

  # Network Resources (from Prerequisites)
  VpcId:
    Type: AWS::EC2::VPC::Id
    Description: VPC ID

  PublicSubnetId:
    Type: AWS::EC2::Subnet::Id
    Description: Public subnet ID for login nodes

  PrivateSubnetId:
    Type: AWS::EC2::Subnet::Id
    Description: Private subnet ID for compute nodes

  SecurityGroupId:
    Type: AWS::EC2::SecurityGroup::Id
    Description: Security group ID for cluster instances

  # FSx Resources (from Prerequisites)
  FSxLustreFilesystemId:
    Type: String
    Description: FSx for Lustre filesystem ID

  FSxLustreFilesystemMountName:
    Type: String
    Description: FSx for Lustre mount name

  FSxOpenZFSFilesystemId:
    Type: String
    Description: FSx for OpenZFS filesystem ID

  # S3 Configuration
  S3BucketName:
    Type: String
    Description: S3 bucket name for nested templates
    Default: "awsome-distributed-ai"

  S3KeyPrefix:
    Type: String
    Description: S3 key prefix for nested templates
    Default: "templates/"

  # PCS Cluster Configuration
  SlurmVersion:
    Type: String
    Default: "25.11"
    AllowedValues:
      - "25.05"
      - "25.11"

  ManagedAccounting:
    Type: String
    Default: 'disabled'
    AllowedValues:
      - 'enabled'
      - 'disabled'

  AccountingPolicyEnforcement:
    Type: String
    Default: none
    AllowedValues:
      - none
      - 'associations,limits,safe'

  DeployMonitoring:
    Type: String
    Default: 'true'
    AllowedValues:
      - 'true'
      - 'false'

  MonitoringVersion:
    Type: String
    Default: 'latest'

  LoginNodeInstanceType:
    Type: String
    Default: "m6i.4xlarge"

  # AMI Configuration
  AmiId:
    Type: String
    Description: AMI ID for cluster instances (custom or base DLAMI)

  InstallEnrootPyxis:
    Type: String
    Default: 'false'
    AllowedValues:
      - 'true'
      - 'false'

  # On-Demand Compute Node Group
  DeployOnDemandCNG:
    Type: String
    Default: 'true'
    AllowedValues:
      - 'true'
      - 'false'

  OnDemandCngName:
    Type: String
    Default: "cpu1"

  OnDemandQueueName:
    Type: String
    Default: "cpu1"

  OnDemandInstanceType:
    Type: String
    Default: "c6i.4xlarge"

  OnDemandMaxCount:
    Type: Number
    Default: 4
    MinValue: 0

  OnDemandMinCount:
    Type: Number
    Default: 0
    MinValue: 0

  # P-series Compute Node Group
  DeployPseriesCNG:
    Type: String
    Default: 'false'
    AllowedValues:
      - 'true'
      - 'false'

  PseriesCngName:
    Type: String
    Default: "gpu-p5"

  PseriesQueueName:
    Type: String
    Default: "gpu-p5"

  PseriesInstanceType:
    Type: String
    Default: "p5.48xlarge"
    AllowedValues:
      - p5.48xlarge
      - p5e.48xlarge
      - p5en.48xlarge

  PseriesMaxCount:
    Type: Number
    Default: 4
    MinValue: 0

  PseriesMinCount:
    Type: Number
    Default: 0
    MinValue: 0

  NetworkInterfaceCount:
    Type: Number
    Default: 32
    AllowedValues:
      - 16
      - 32

  CapacityReservationId:
    Type: String
    Default: ""
    Description: Optional Capacity Reservation ID for P-series instances

Conditions:
  UseLocalTemplates: !Equals [!Ref S3BucketName, 'local']
  DeployOnDemandCNGEnabled: !Equals [!Ref DeployOnDemandCNG, 'true']
  DeployPseriesCNGEnabled: !Equals [!Ref DeployPseriesCNG, 'true']
  DeployMonitoringEnabled: !Equals [!Ref DeployMonitoring, 'true']
  HasCapacityReservation: !Not [!Equals [!Ref CapacityReservationId, '']]

Resources:
  #############################################################################
  # 1. PCS Cluster Stack
  #############################################################################
  ClusterStack:
    Type: AWS::CloudFormation::Stack
    Properties:
      TemplateURL: !If
        - UseLocalTemplates
        - cluster.yaml
        - !Sub 'https://${S3BucketName}.s3.amazonaws.com/${S3KeyPrefix}cluster.yaml'
      Parameters:
        ClusterName: !Ref ClusterStackName
        VpcId: !Ref VpcId
        PublicSubnetId: !Ref PublicSubnetId
        PrivateSubnetId: !Ref PrivateSubnetId
        DefaultSecurityGroupId: !Ref SecurityGroupId
        FSxLustreFilesystemId: !Ref FSxLustreFilesystemId
        FSxLustreFilesystemMountName: !Ref FSxLustreFilesystemMountName
        FSxOpenZFSFilesystemId: !Ref FSxOpenZFSFilesystemId
        SlurmVersion: !Ref SlurmVersion
        ManagedAccounting: !Ref ManagedAccounting
        AccountingPolicyEnforcement: !Ref AccountingPolicyEnforcement
        DeployMonitoring: !Ref DeployMonitoring
      Tags:
        - Key: Name
          Value: !Sub '${ClusterStackName}-Cluster'

  #############################################################################
  # 2. Login Node Group Stack
  #############################################################################
  LoginNodeGroupStack:
    Type: AWS::CloudFormation::Stack
    DependsOn: ClusterStack
    Properties:
      TemplateURL: !If
        - UseLocalTemplates
        - add-cng.yaml
        - !Sub 'https://${S3BucketName}.s3.amazonaws.com/${S3KeyPrefix}add-cng.yaml'
      Parameters:
        ClusterId: !GetAtt ClusterStack.Outputs.ClusterId
        ClusterName: !Ref ClusterStackName
        CngName: login
        QueueName: ""
        InstanceType: !Ref LoginNodeInstanceType
        MaxCount: 1
        MinCount: 1
        SubnetId: !Ref PublicSubnetId
        AmiId: !Ref AmiId
        ClusterSecurityGroupId: !Ref SecurityGroupId
        IamProfileArn: !GetAtt ClusterStack.Outputs.InstanceProfileArn
        FSxLustreFilesystemId: !Ref FSxLustreFilesystemId
        FSxLustreFilesystemMountName: !Ref FSxLustreFilesystemMountName
        FSxOpenZFSFilesystemId: !Ref FSxOpenZFSFilesystemId
        DeployMonitoring: !Ref DeployMonitoring
        MonitoringVersion: !Ref MonitoringVersion
        MonitoringRole: !If [DeployMonitoringEnabled, 'login', 'none']
        InstallEnrootPyxis: !Ref InstallEnrootPyxis
      Tags:
        - Key: Name
          Value: !Sub '${ClusterStackName}-LoginNodeGroup'

  #############################################################################
  # 3. On-Demand Compute Node Group Stack
  #############################################################################
  OnDemandCNGStack:
    Type: AWS::CloudFormation::Stack
    Condition: DeployOnDemandCNGEnabled
    DependsOn: ClusterStack
    Properties:
      TemplateURL: !If
        - UseLocalTemplates
        - add-cng.yaml
        - !Sub 'https://${S3BucketName}.s3.amazonaws.com/${S3KeyPrefix}add-cng.yaml'
      Parameters:
        ClusterId: !GetAtt ClusterStack.Outputs.ClusterId
        ClusterName: !Ref ClusterStackName
        CngName: !Ref OnDemandCngName
        QueueName: !Ref OnDemandQueueName
        InstanceType: !Ref OnDemandInstanceType
        MaxCount: !Ref OnDemandMaxCount
        MinCount: !Ref OnDemandMinCount
        SubnetId: !Ref PrivateSubnetId
        AmiId: !Ref AmiId
        ClusterSecurityGroupId: !Ref SecurityGroupId
        IamProfileArn: !GetAtt ClusterStack.Outputs.InstanceProfileArn
        FSxLustreFilesystemId: !Ref FSxLustreFilesystemId
        FSxLustreFilesystemMountName: !Ref FSxLustreFilesystemMountName
        FSxOpenZFSFilesystemId: !Ref FSxOpenZFSFilesystemId
        DeployMonitoring: !Ref DeployMonitoring
        MonitoringVersion: !Ref MonitoringVersion
        MonitoringRole: 'none'
        InstallEnrootPyxis: !Ref InstallEnrootPyxis
      Tags:
        - Key: Name
          Value: !Sub '${ClusterStackName}-OnDemandCNG'

  #############################################################################
  # 4. P-series Compute Node Group Stack
  #############################################################################
  PseriesCNGStack:
    Type: AWS::CloudFormation::Stack
    Condition: DeployPseriesCNGEnabled
    DependsOn: ClusterStack
    Properties:
      TemplateURL: !If
        - UseLocalTemplates
        - add-cng-p5.yaml
        - !Sub 'https://${S3BucketName}.s3.amazonaws.com/${S3KeyPrefix}add-cng-p5.yaml'
      Parameters:
        ClusterId: !GetAtt ClusterStack.Outputs.ClusterId
        ClusterName: !Ref ClusterStackName
        CngName: !Ref PseriesCngName
        QueueName: !Ref PseriesQueueName
        InstanceType: !Ref PseriesInstanceType
        MaxCount: !Ref PseriesMaxCount
        MinCount: !Ref PseriesMinCount
        SubnetId: !Ref PrivateSubnetId
        AmiId: !Ref AmiId
        ClusterSecurityGroupId: !Ref SecurityGroupId
        IamProfileArn: !GetAtt ClusterStack.Outputs.InstanceProfileArn
        FSxLustreFilesystemId: !Ref FSxLustreFilesystemId
        FSxLustreFilesystemMountName: !Ref FSxLustreFilesystemMountName
        FSxOpenZFSFilesystemId: !Ref FSxOpenZFSFilesystemId
        NetworkInterfaceCount: !Ref NetworkInterfaceCount
        CapacityReservationId: !If [HasCapacityReservation, !Ref CapacityReservationId, !Ref 'AWS::NoValue']
        DeployMonitoring: !Ref DeployMonitoring
        MonitoringVersion: !Ref MonitoringVersion
        MonitoringRole: 'none'
        InstallEnrootPyxis: !Ref InstallEnrootPyxis
      Tags:
        - Key: Name
          Value: !Sub '${ClusterStackName}-PseriesCNG'

Outputs:
  ClusterId:
    Description: PCS Cluster ID
    Value: !GetAtt ClusterStack.Outputs.ClusterId
    Export:
      Name: !Sub '${AWS::StackName}-ClusterId'

  InstanceProfileArn:
    Description: IAM Instance Profile ARN
    Value: !GetAtt ClusterStack.Outputs.InstanceProfileArn
    Export:
      Name: !Sub '${AWS::StackName}-InstanceProfileArn'

  LoginNodeGroupId:
    Description: Login Node Group ID
    Value: !GetAtt LoginNodeGroupStack.Outputs.ComputeNodeGroupId
    Export:
      Name: !Sub '${AWS::StackName}-LoginNodeGroupId'

  OnDemandCNGId:
    Condition: DeployOnDemandCNGEnabled
    Description: On-Demand Compute Node Group ID
    Value: !GetAtt OnDemandCNGStack.Outputs.ComputeNodeGroupId
    Export:
      Name: !Sub '${AWS::StackName}-OnDemandCNGId'

  PseriesCNGId:
    Condition: DeployPseriesCNGEnabled
    Description: P-series Compute Node Group ID
    Value: !GetAtt PseriesCNGStack.Outputs.ComputeNodeGroupId
    Export:
      Name: !Sub '${AWS::StackName}-PseriesCNGId'

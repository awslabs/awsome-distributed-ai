#
# Environment variables for Qwen GRPO experiments
# Copy this to env_vars and fill in your values:
#   cp env_vars.example env_vars && vim env_vars
#   source env_vars

# === AWS Configuration ===
export AWS_PROFILE="compute-sa"
export AWS_REGION="us-east-2"
export ACCOUNT_ID="159553542841"
export ECR_REGISTRY="${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"

# === Cluster Configuration ===
export CLUSTER_NAME="your-eks-cluster"
export NAMESPACE="default"
export SERVICE_ACCOUNT="compute-sa"

# === Image Configuration ===
export IMAGE_NAME="qwen-grpo-experiments"
export IMAGE_TAG="latest"
export FULL_IMAGE="${ECR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}"

# === Model Configuration ===
export MODEL_NAME="Qwen2.5-7B-Instruct"
export MODEL_PATH="Qwen/Qwen2.5-7B-Instruct"

# === Storage ===
export FSX_PVC="fsx-claim"
export DATA_HOME="/fsx/qwen-grpo"
export CKPT_HOME="/fsx/qwen-grpo/checkpoints"

# === Ray Configuration ===
export RAY_ADDRESS="http://localhost:8265"
export NUM_NODES=2
export NUM_GPU_PER_NODE=8

# === Training Hyperparams ===
export SFT_LR="2e-5"
export GRPO_LR="1e-6"
export LORA_RANK=16
export LORA_ALPHA=32
export SFT_EPOCHS=3
export GRPO_EPOCHS=3
export GRPO_N_SAMPLES=8
export GRPO_TEMPERATURE=0.7

# === Experiment Tracking ===
export WANDB_PROJECT="qwen-grpo-experiments"
export WANDB_ENTITY=""  # Set to your W&B team

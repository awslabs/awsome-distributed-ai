# ============================================================
# SLIME on HyperPod EKS - Environment Variables (COLOCATED)
#
# Baseline single-pool config: training (Megatron) and rollout (SGLang) share
# the same GPUs, with an in-process built-in reward. This is the simplest setup.
#
# Copy this file to env_vars and fill in your values:
#   cp env_vars.colocated.example env_vars && vim env_vars
# ============================================================

# ----- AWS / ECR -----
# Region and account are derived from your current AWS credentials/config so
# nothing environment-specific is hard-coded. Override AWS_REGION if needed.
export AWS_REGION="${AWS_REGION:-$(aws configure get region)}"
export AWS_ACCOUNT_ID="$(aws sts get-caller-identity --query Account --output text)"
export REGISTRY="${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/"
export IMAGE="slime-hyperpod"
export TAG="slime0.2.4-sgl0.5.12"   # pinned image tag; avoid ":latest"
export FULL_IMAGE="${REGISTRY}${IMAGE}:${TAG}"

# ----- HuggingFace -----
export HF_TOKEN=""   # <-- Set your HuggingFace token here

# ----- Model Configuration -----
# Choose one of the configurations below by uncommenting.

# --- Option A: Qwen3-4B (Dense, Colocated mode) ---
export MODEL_NAME="Qwen/Qwen3-4B"
export MODEL_LOCAL="/fsx/models/Qwen3-4B"
export MODEL_DIST="/fsx/models/Qwen3-4B_torch_dist"
export COLOCATE="true"
export TP_SIZE=1
export PP_SIZE=1
export CP_SIZE=1
export EP_SIZE=1
export ROLLOUT_NUM_GPUS=16
export ROLLOUT_GPUS_PER_ENGINE=1
export ACTOR_NUM_NODES=2
export ACTOR_GPUS_PER_NODE=8
export MAX_TOKENS_PER_GPU=8192
export ROLLOUT_MAX_RESPONSE_LEN=8192
export MODEL_SCRIPT="qwen3-4B.sh"

# --- Option B: GLM-Z1-9B (Dense, Colocated mode) ---
# export MODEL_NAME="zai-org/GLM-Z1-9B-0414"
# export MODEL_LOCAL="/fsx/models/GLM-Z1-9B-0414"
# export MODEL_DIST="/fsx/models/GLM-Z1-9B-0414_torch_dist"
# export COLOCATE="true"
# export TP_SIZE=2
# export PP_SIZE=1
# export CP_SIZE=2
# export EP_SIZE=1
# export ROLLOUT_NUM_GPUS=16
# export ROLLOUT_GPUS_PER_ENGINE=2
# export ACTOR_NUM_NODES=2
# export ACTOR_GPUS_PER_NODE=8
# export MAX_TOKENS_PER_GPU=4608
# export ROLLOUT_MAX_RESPONSE_LEN=8192
# export MODEL_SCRIPT="glm4-9B.sh"

# --- Option C: Qwen3-30B-A3B (MoE, Disaggregated mode) ---
# export MODEL_NAME="Qwen/Qwen3-30B-A3B"
# export MODEL_LOCAL="/fsx/models/Qwen3-30B-A3B"
# export MODEL_DIST="/fsx/models/Qwen3-30B-A3B_torch_dist"
# export COLOCATE="false"
# export TP_SIZE=2
# export PP_SIZE=1
# export CP_SIZE=2
# export EP_SIZE=2
# export ROLLOUT_NUM_GPUS=4
# export ROLLOUT_GPUS_PER_ENGINE=2
# export ACTOR_NUM_NODES=2
# export ACTOR_GPUS_PER_NODE=8
# export MAX_TOKENS_PER_GPU=4096
# export ROLLOUT_MAX_RESPONSE_LEN=8192
# export MODEL_SCRIPT="qwen3-30B-A3B.sh"

# ----- Cluster -----
export NAMESPACE="default"
export FSX_CLAIM="fsx-claim"
export NUM_NODES=2
export GPUS_PER_NODE=8
export TOTAL_GPUS=$((NUM_NODES * GPUS_PER_NODE))

# ----- Training -----
export PROMPT_DATA="/fsx/data/dapo-math-17k/dapo-math-17k.jsonl"
export EVAL_DATA="/fsx/data/aime-2024/aime-2024.jsonl"
export CHECKPOINT_DIR="/fsx/checkpoints"
export SAVE_INTERVAL=20
export NUM_ROLLOUT=100
export ROLLOUT_BATCH_SIZE=16
export N_SAMPLES_PER_PROMPT=8
export GLOBAL_BATCH_SIZE=128
export LEARNING_RATE="1e-6"
export ROLLOUT_TEMPERATURE=1.0

# ----- Reward -----
# Default: in-process rule-based reward (runs on the GPU rollout nodes).
# Built-in types include: deepscaler, dapo, math, f1, gpqa.
export RM_TYPE="deepscaler"
# To use a custom in-process reward function instead, point at a module:function
# (see SLIME's --custom-rm-path), e.g.:
# export CUSTOM_RM_PATH="/fsx/slime/reward/my_reward:reward_func"

# ----- Remote Reward Service (optional, CPU instance group) -----
# Offload reward scoring to a CPU-hosted HTTP service in the SAME AZ (see
# kubernetes/reward-service.yaml). Recommended when the reward is heavy (a
# reward MODEL, code-exec, RAG) so it does not steal CPU from the GPU actors.
# To enable: set RM_TYPE="remote_rm" above and configure the values below.
export REWARD_IMAGE="${REGISTRY}slime-reward:cpu"
export REWARD_BACKEND="reward_model"   # or "math_verify"
export REWARD_MODEL_NAME="OpenAssistant/reward-model-deberta-v3-large-v2"
export REWARD_REPLICAS=4
# HyperPod CPU instance group that hosts the reward pods (Spot-capacity c5 pool).
export REWARD_NODE_GROUP="reward-spot-c5"
export REWARD_TORCH_THREADS=4
# Cluster-internal DNS of the reward Service (namespace-scoped):
export RM_URL="http://slime-reward.${NAMESPACE}.svc.cluster.local:8000/score"


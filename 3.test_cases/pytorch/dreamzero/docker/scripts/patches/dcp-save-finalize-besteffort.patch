@@ -233,10 +233,37 @@ class FSDPStrategyBase(ABC):
                 from torch.distributed import checkpoint as dcp
 
                 dcp_save_path = os.path.join(save_path, "dcp_checkpoint")
-                dcp.save(
-                    {"fsdp_checkpoint": training_state},

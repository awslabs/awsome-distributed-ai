#
# PointWorld flagship pre-training configuration: multi-domain DROID + BEHAVIOR,
# large PTv3 backbone. Targets 8 x p5en.48xlarge (64 x H200).
#
# PointWorld's train.py is CLI-driven (see arguments.py upstream), not YAML-driven.
# This file documents the canonical flag set as shell-style key/values so it can
# be sourced by launch wrappers or copied into the PyTorchJob "args" list. The
# kubernetes/pointworld-pretrain.yaml manifest encodes the same values directly.
#
# Reference (single source of truth):
#   https://github.com/NVlabs/PointWorld  (train.py / arguments.py)

# --- domains & data ---------------------------------------------------------
# Multi-domain training expects one data dir per domain, 1:1 with --domains.
# LOCAL_DATASET_DIR defaults to /dataset in the container; with WDS shards at
# /dataset/droid/wds and /dataset/behavior/wds the --data_dirs can be omitted
# (arguments.py maps domains -> dirs automatically), but we set them explicitly.
DOMAINS=droid,behavior
DATA_DIRS=/dataset/droid/wds,/dataset/behavior/wds

# Normalization stats. Multi-domain DROID+BEHAVIOR uses the joint stats folder
# shipped in the repo at stats/droid_behavior.
NORM_STATS_PATH=stats/droid_behavior

# --- model ------------------------------------------------------------------
PTV3_SIZE=large
PTV3_PATCH_SIZE=256
PREDICTOR_DIM=256

# --- optimization -----------------------------------------------------------
# Per-GPU batch size. arguments.py default is 22; tune to fit 141 GB H200 HBM.
BATCH_SIZE=22
BASE_LR=0.0001
WEIGHT_DECAY=0.01
GRAD_CLIP_MAX_NORM=5.0
NUM_EPOCHS=200

# --- dataloading ------------------------------------------------------------
NUM_WORKERS=16
EVAL_NUM_WORKERS=5

# --- checkpoint / eval cadence (in steps) -----------------------------------
SAVE_FREQ=1800
# Disable periodic in-loop eval during pure pre-training benchmarks; run eval.py
# separately afterwards (kubernetes/pointworld-eval.yaml).
EVAL_FREQ=-1

# --- distributed ------------------------------------------------------------
DISTRIBUTED=true

# --- logging ----------------------------------------------------------------
LOG_DIR=/fsx/pointworld/train_logs
EXP_NAME=pointworld-large-droid-behavior
# Set to "disabled" to turn off Weights & Biases (recommended for CI/benchmarks).
WANDB_MODE=disabled

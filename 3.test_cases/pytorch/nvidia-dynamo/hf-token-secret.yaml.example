#
# Reference only — the models in this test case are PUBLIC, so this Secret is not
# required. Create it ONLY if you swap in a gated model. The recommended path is
# `kubectl create secret` (keeps the token out of source control):
#
#   kubectl create secret generic hf-token-secret \
#     --namespace dynamo-system \
#     --from-literal=HF_TOKEN="${HF_TOKEN}"
#
# scripts/01-install-platform.sh already creates this secret from $HF_TOKEN.
# If you prefer a manifest, copy this file to hf-token-secret.yaml, fill in the
# base64 value, and `kubectl apply -f` it. DO NOT commit the filled-in version.
apiVersion: v1
kind: Secret
metadata:
  name: hf-token-secret
  namespace: dynamo-system
type: Opaque
stringData:
  HF_TOKEN: "REPLACE_WITH_YOUR_HF_TOKEN"
